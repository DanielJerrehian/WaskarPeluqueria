# ── Square ────────────────────────────────────────────────────────────────────
# Get from: Square Developer Dashboard → Your App → Production → Access Token
SQUARE_ACCESS_TOKEN=

# ── Resend ────────────────────────────────────────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=
# Must match a verified sender domain in Resend
# RESEND_FROM_EMAIL=Waskar Peluquería <hola@waskarpeluqueria.com>
RESEND_FROM_EMAIL=onboarding@resend.dev
# Get from: Resend Dashboard → Audiences → copy ID
RESEND_AUDIENCE_ID=

# ── Google Reviews ────────────────────────────────────────────────────────────
# Get from: Google Business Profile → Ask for reviews → Copy link
GOOGLE_REVIEW_URL=

# ── Cron Security ─────────────────────────────────────────────────────────────
# Any long random string — used to protect the cron endpoint
# Generate: openssl rand -hex 32
CRON_SECRET=